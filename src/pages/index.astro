---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import Hero from "../components/Hero.astro";
import Youtube from "../components/Youtube.astro";
import PatagoniaLogo from "../assets/patagonia.png";
import SalmonWatch from "../assets/salmonwatchireland.jpg";
import Onepercent from "../assets/1ftp_blue.png";
import ERB from "../assets/ERB.png";
import {
  results2026,
  results2025,
  results2024,
  results2023,
} from "../data/results/results.js";

type TimelineEntry = {
  title: string;
  link: string | null;
  date: string | null;
};

const timelineByYear = {
  "2026": results2026.results as TimelineEntry[],
  "2025": results2025.results as TimelineEntry[],
  "2024": results2024.results as TimelineEntry[],
  "2023": results2023.results as TimelineEntry[],
};

const timelineYears = ["2026", "2025", "2024", "2023"] as const;
---

<Layout title="DEFENSE DES MILIEUX AQUATIQUES">
  <div x-data="{ selectedTab: '2026' }" class="w-full">
    <div class="timeline-wrapper">
      <div
        @keydown.right.prevent="$focus.wrap().next()"
        @keydown.left.prevent="$focus.wrap().previous()"
        class="timeline-years overflow-x-auto"
        role="tablist"
        aria-label="tab options"
      >
        <h2 class="p-4 text-xl font-bold">Nos résultats:</h2>
        <button
          @click="selectedTab = '2026'"
          :aria-selected="selectedTab === '2026'"
          :tabindex="selectedTab === '2026' ? '0' : '-1'"
          :class="selectedTab === '2026' ? 'text-white font-bold  border-b-2 border-white' : 'text-blue-200 font-medium  dark:hover:border-b-neutral-300  hover:border-b-2 hover:border-b-neutral-800 '"
          class="h-min text-sm"
          type="button"
          role="tab"
          aria-controls="tabpanelGroups">2026</button
        >
        <button
          @click="selectedTab = '2025'"
          :aria-selected="selectedTab === '2025'"
          :tabindex="selectedTab === '2025' ? '0' : '-1'"
          :class="selectedTab === '2025' ? 'text-white font-bold  border-b-2 border-white' : 'text-blue-200 font-medium  dark:hover:border-b-neutral-300  hover:border-b-2 hover:border-b-neutral-800 '"
          class="h-min text-sm"
          type="button"
          role="tab"
          aria-controls="tabpanelGroups">2025</button
        >
        <button
          @click="selectedTab = '2024'"
          :aria-selected="selectedTab === '2024'"
          :tabindex="selectedTab === '2024' ? '0' : '-1'"
          :class="selectedTab === '2024' ? 'text-white font-bold border-b-2 border-white' : 'text-blue-200 font-medium dark:hover:border-b-neutral-300  hover:border-b-2 hover:border-b-neutral-800'"
          class="h-min text-sm"
          type="button"
          role="tab"
          aria-controls="tabpanelGroups">2024</button
        >
        <button
          @click="selectedTab = '2023'"
          :aria-selected="selectedTab === '2023'"
          :tabindex="selectedTab === '2023' ? '0' : '-1'"
          :class="selectedTab === '2023' ? 'text-white font-bold border-b-2 border-white' : 'text-blue-200 font-medium dark:hover:border-b-neutral-300  hover:border-b-2 hover:border-b-neutral-800'"
          class="h-min text-sm"
          type="button"
          role="tab"
          aria-controls="tabpanelGroups">2023</button
        >
      </div>
    </div>
    <div class="hero-wrapper">
      <div class="hero-timeline">
        {
          timelineYears.map((year) => (
            <ul
              x-show={`selectedTab === '${year}'`}
              id="tabpanelGroups"
              role="tabpanel"
              aria-label={year}
              class="jugements-list"
            >
              {timelineByYear[year].map((entry) => (
                <li>
                  {entry.link ? (
                    <a href={entry.link} target="_blank" rel="noopener">
                      {entry.title}
                    </a>
                  ) : (
                    entry.title
                  )}
                  {entry.date && <span class="tag">{entry.date}</span>}
                </li>
              ))}
            </ul>
          ))
        }
        <p class="keep-fighting">
          <strong>👇 Défendons les milieux aquatiques ensemble 👇</strong>
        </p>
      </div>
    </div>
  </div>
  <Hero>
    <div class="text-white mb-12 text-left text-6xl uppercase">
      <div class="font-bold">Protéger</div>
      <div class="text-4xl">les rivières</div>
      <div class="text-4xl">les estuaires</div>
      <div class="text-4xl">et les océans</div>
      <div class="font-bold">par le droit</div>
    </div>
    <form
      action="https://buttondown.email/api/emails/embed-subscribe/defensedesmilieuxaquatiques"
      method="post"
      target="popupwindow"
      onsubmit="window.open('https://buttondown.email/defensedesmilieuxaquatiques', 'popupwindow')"
      class="embeddable-buttondown-form"
    >
      <input
        type="email"
        name="email"
        id="bd-email"
        placeholder="votre adresse email"
      />
      <input class="btn-hero" type="submit" value="nous rejoindre" />
    </form>
  </Hero>
  <main>
    <div class="container">
      <section>
        <ul role="list" class="link-card-grid">
          <Card
            href="/equipe"
            title="L'Association"
            body="Présentation de notre association"
          />
          <Card
            href="/notre-grand-projet"
            title="Notre Grand Projet"
            body="Golden Miles, REO plutot RMD"
          />
          <Card
            href="/historique"
            title="Résultats Juridiques"
            body="Les résultats juridiques de notre association"
          />
          <Card
            href="/nous-aider"
            title="Comment nous aider"
            body="Dons de temps et d'argent, vous pouvez nous aider de plusieurs façons"
          />
          <Card
            href="/blog"
            title="Actualités"
            body="Retrouvez nos dernières actualités"
          />
          <Card
            href="/contact"
            title="Contact"
            body="Contactez notre association"
          />
        </ul>
      </section>
      <aside>
        <Youtube videoid="B5v8VxF3uh4" />
      </aside>
    </div>
    <section class="video">
      <div>
        <div class="video__summary">
          <h3>La Rivière <span>de Dominique Marchais</span></h3>
          <p>
            Entre Pyrénées et Atlantique coulent des rivières puissantes qu’on
            appelle les gaves. Les champs de maïs les assoiffent, les barrages
            bloquent la circulation du saumon. L’activité humaine bouleverse le
            cycle de l’eau et la biodiversité de la rivière. Des hommes et des
            femmes tendent leur regard curieux et amoureux vers ce monde
            fascinant fait de beauté et de désastre.
          </p>
          <p>Au cinéma le 22 novembre 2023</p>
        </div>
        <Youtube videoid="EtIcELoNdNI" />
      </div>
    </section>
    <section class="podcast">
      <div class="mb-4">
        <h3>Podcast</h3>
        <p>
          Guillaume MEURICE fait découvrir le sujet de la pêche maritime à deux
          adolescents Ilio et Enna. Leur curiosité et leur pertinence
          transcendent cette géniale émission. Défense des milieux Aquatiques a
          eu le privilège de répondre à Ilio et Enna avec une certaine émotion.
        </p>
      </div>
      <iframe
        style="border-radius:12px"
        src="https://open.spotify.com/embed/episode/2yQRNaXkDjzME12VGOrWpT?utm_source=generator"
        width="100%"
        height="352"
        frameborder="0"
        allowfullscreen=""
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        loading="lazy"></iframe>
      <a
        href="https://www.radiofrance.fr/franceinter/podcasts/mission-poseidon"
        target="_blank"
        rel="noopener">👉 Ecoutez la suite sur France Inter 👈</a
      >
    </section>
    <section class="podcast">
      <div class="mb-4">
        <h3>Partenaires</h3>
        <div class="flex justify-center items-center gap-4 mt-4">
          <a href="https://www.patagoniaworks.com/#index">
            <img alt={"Patagonia"} width={220} src={PatagoniaLogo.src} />
          </a>
          <a href="https://salmonwatchireland.ie">
            <img alt={"SalmonWatch"} width={336} src={SalmonWatch.src} />
          </a>
          <a href="https://onepercentfortheplanet.org/">
            <img
              alt={"One Percent For The Planet"}
              width={200}
              src={Onepercent.src}
            />
          </a>
          <a href="https://www.eau-et-rivieres.org/">
            <img
              alt={"Eau et Rivières de Bretagne"}
              width={200}
              src={ERB.src}
            />
          </a>
        </div>
      </div>
    </section>
  </main>
  <section class="newsletter">
    <h3>Restez informé! Je veux recevoir la newsletter</h3>
    <form
      action="https://buttondown.email/api/emails/embed-subscribe/defensedesmilieuxaquatiques"
      method="post"
      target="popupwindow"
      onsubmit="window.open('https://buttondown.email/defensedesmilieuxaquatiques', 'popupwindow')"
      class="embeddable-buttondown-form"
    >
      <input
        type="email"
        name="email"
        id="bd-email"
        placeholder="votre adresse email"
      />
      <input id="formButton" type="submit" value="m'inscrire" />
    </form>
    <!-- <ul class="social-media">
      <li>
        <img src={youtubeIcon.src} width={36} alt="Youtube Icon" />
      </li>
      <li>
        <img src={instagramIcon.src} width={36} alt="Instagram Icon" />
      </li>
      <li>
        <img src={facebookIcon.src} width={36} alt="Facebook Icon" />
      </li>
    </ul> -->
  </section>
  <section class="container-lg">
    <div class="description">
      <div>
        <h3>Défense des milieux aquatiques</h3>
        <p>
          DMA a pour vocation exclusive d'agir pour la défense, la protection et
          la conservation de l'intégrité du milieu aquatique naturel en général
          ; plus particulièrement marin et de toutes les espèces dépendantes de
          ce milieu, telles que par exemple les poissons et tous les organismes
          connus ou à découvrir sans exception, y compris les mammifères marins,
          les reptiles, les oiseaux, mais aussi les habitats concernés.
        </p>
      </div>
      <div class="link-container">
        <ul>
          <li data-icon="🐟">
            <h3 class="link-hover">
              <a href="/notre-grand-projet">Sensibilisation</a>
            </h3>
          </li>
          <li data-icon="🦀">
            <h3 class="link-hover">
              <a href="/blog">Actions</a>
            </h3>
          </li>
          <li data-icon="🐚">
            <h3 class="link-hover">
              <a href="/especes-defendues">Protection</a>
            </h3>
          </li>
        </ul>
      </div>
    </div>
  </section>
  <section class="situation-urgente">
    <h3>Une situation urgente</h3>
    <p>
      L'officialisation du chalutage au ras des côtes girondines depuis des
      dizaines d'années, la baisse du stock de bar du Golfe de Gascogne et la
      privatisation rampante de sa pêche, l'absence de zones côtières
      débarrassées de filets, l'absence de volonté politique et de contrôle
      efficace pour repousser les pratiques non-conformes, le scandale de la
      pêcherie du maigre, le drame des salmonidés de l'Adour et de la Gironde ne
      sont que quelques uns des sujets qui préoccupent DMA.
    </p>
    <p>
      <strong>L'association n'est pas opposée à la pêche,</strong>
      laquelle est indispensable à des centaines de millions de personnes dans le
      monde, car l’économie fait également partie du processus de sauvegarde et un
      équilibre doit être trouvé entre les différents acteurs de ce milieu.
    </p>
    <p>
      Toutefois, l'association use de tous les moyens juridiques qui sont à sa
      disposition pour <strong>atteindre des pratiques de pêche durables</strong
      > : préserver la biodiversité aquatique en envisageant uniquement l'aspect environnemental
      ne suffit pas, notre stratégie repose donc sur la triple condition socio-économique
      et environnementale.
    </p>
    <p>
      Aussi, DMA tente de démontrer le bien-fondé de ses propositions sous ce
      triple aspect et élaborer des stratégies gagnant-gagnant afin de
      neutraliser les pressions et les blocages qui ont permis de tisser une
      véritable toile d'inepties. Enfin, <strong>
        notre objectif est d'agir comme catalyseur du changement</strong
      >. Ainsi, depuis nos débuts, en 2017, nous portons les idées sur
      lesquelles notre organisation sans but lucratif a été fondée : la
      sensibilisation, la protection et l'action.
    </p>
  </section>
</Layout>

<style>
  main {
    margin: auto;
    padding: 1.5rem;
    max-width: 1200px;
    display: flex;
    flex-direction: column;
    background-color: var(--background-grey);
  }
  main > div {
    gap: 2rem;
  }
  .container > section {
    flex: 2;
  }
  .container {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    width: 100%;
    flex-wrap: wrap;
    margin-top: -100px;
  }
  h1,
  h3 {
    text-transform: uppercase;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--dma-blue);
    margin: 0;
  }
  .link-container > ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 1rem;
  }
  .link-container > ul > li {
    display: grid;
    grid-template-columns: 0 1fr;
    gap: 1.75em;
    align-items: start;
    font-size: 1.5rem;
    line-height: 1.25;
  }
  .link-container > ul > li::before {
    content: attr(data-icon);
    /* Make slightly larger than the li font-size
  but smaller than the li gap */
    font-size: 1.25em;
  }

  aside {
    flex: 1;
    background-color: var(--dma-blue);
    color: white;
    padding: 0.5rem;
    margin-top: auto;
    margin-bottom: auto;
    position: relative;
    min-width: 300px;
  }

  .newsletter {
    position: relative;
    min-height: 300px;
    color: white;
    text-align: center;
    padding: 3rem;
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    background-color: #0d4ab2a6;
    background-image: url("/images/newsletter.jpg");
    background-blend-mode: overlay;
    border-radius: 6px;
    z-index: 2;
  }

  .newsletter h3 {
    color: white;
    z-index: 2;
  }

  .newsletter > ul {
    z-index: 2;
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: row;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }

  .newsletter > form {
    z-index: 2;
  }

  form {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }

  form > #formButton {
    padding: 0.7rem;
    font-size: 1.1rem;
    color: var(--dma-blue);
    background-color: white;
    border: none;
    font-weight: bold;
    text-transform: uppercase;
    margin: 0.5rem;
  }
  form > input:not([type="submit"]) {
    height: 42px;
    padding-left: 1rem;
    border-radius: 3px;
    border: none;
    font-size: 1.2rem;
  }
  .description {
    margin: 4rem auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
    font-size: 1.4rem;
    padding: 2rem;
    line-height: 1.5;
    background-color: white;
  }
  .link-container {
    place-self: center;
  }
  .link-hover {
    position: relative;
    width: fit-content;
    color: var(--dma-blue);
    margin-top: 0.2rem;
    margin-bottom: 0.2rem;
  }
  .link-hover > a {
    position: relative;
    z-index: 2;
    text-decoration: none;
    color: var(--dma-blue);
  }
  .link-hover:hover > a {
    color: white;
  }
  .link-hover::after {
    content: "";
    position: absolute;
    background-color: var(--dma-blue);
    inset: 16px 0 0 0;
    z-index: 1;
    transform: scaleY(0.2);
    transition: all 100ms ease;
    height: 20px;
  }

  .link-hover:hover::after {
    transform: scaleY(1.4);
    inset: 0 0 0 0;
  }

  .text-gradient {
    background-image: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 400%;
    background-position: 0%;
  }
  .link-card-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(24ch, 1fr));
    gap: 1rem;
    padding: 0;
  }
  .situation-urgente {
    margin: auto;
    max-width: 800px;
    font-size: 1.2rem;
    border: 6px solid var(--dma-blue);
    padding: 2rem;
    line-height: 1.5;
    & h3 {
      margin-bottom: 1rem;
    }
  }
  .btn {
    display: inline;
    background-color: #ff7528;
    color: white;
    padding: 1rem;
    border: none;
    font-weight: 600;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.3ch;
    text-decoration: none;
  }
  .btn-hero {
    display: inline;
    background-color: #ff7528;
    color: white;
    padding: 0.5rem 1rem;
    border: none;
    font-weight: 600;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.1ch;
    text-decoration: none;
  }
  .hero-wrapper {
    background-color: white;
  }
  .timeline-wrapper {
    background-color: var(--dma-blue);
  }
  .hero-timeline {
    max-width: var(--md-size);
    margin: auto;
    color: var(--dma-blue);
    padding-top: 1rem;
    padding-right: 1rem;
    padding-left: 1rem;
    padding-bottom: 2rem;
    background-color: white;
  }

  .hero-timeline ul {
    list-style-type: none;
    padding: 0;
    margin: 0;
  }
  .hero-timeline ul > li {
    margin-top: 1rem;
    font-size: 1.1rem;
    position: relative;
  }
  .hero-timeline ul > li > div {
  }
  .timeline-years h2 {
    color: white;
  }
  .timeline-years {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1rem;
    max-width: var(--md-size);
    margin: auto;
  }
  .tag {
    background-color: var(--dma-blue);
    color: white;
    width: fit-content;
    height: fit-content;
    font-size: 0.75rem;
    font-weight: bold;
    padding: 0.1rem 0.2rem;
    border-radius: 3px;
    white-space: nowrap;
    margin-left: 0.15rem;
  }
  .keep-fighting {
    text-align: center;
    margin-top: 2rem;
  }

  .podcast {
    margin-top: 2rem;
    padding: 1rem;
    background-color: white;
  }
  .podcast > a {
    padding-top: 1rem;
    font-size: 1.2rem;
    margin: auto;
    display: block;
    width: fit-content;
  }
  .video {
    margin-top: 2rem;
    padding: 1rem;
    background-color: white;
  }

  @media (min-width: 768px) {
    .video > div {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .video > div {
      display: flex;
      flex-direction: column;
    }
  }

  .video__summary {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }

  .video__summary h3 > span {
    font-style: italic;
    text-transform: initial;
    font-size: 1rem;
    color: rgb(30, 30, 30);
  }

  .jugements-list a {
    text-decoration: none;
  }
  .jugements-list li:hover a {
    text-decoration: underline;
  }
</style>
